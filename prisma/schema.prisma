// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  TRAVELLER
  BUS_OPERATOR
  RESTAURANT
}

enum BusType {
  AC
  NON_AC
  SLEEPER
  SEMI_SLEEPER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum TripStatus {
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}

// ============================================
// USER MODEL
// ============================================

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  password_hash   String
  full_name       String
  phone           String    @unique
  role            UserRole  @default(TRAVELLER)
  
  // Auth Fields
  otp             String?
  otp_expires_at  DateTime?
  is_verified     Boolean   @default(false)
  
  // Profile Fields
  avatar_url      String?
  address         String?
  
  // Relations based on role
  buses           Bus[]           @relation("BusOperator")
  routes          Route[]         @relation("RouteOperator")
  restaurants     Restaurant[]    @relation("RestaurantOwner")
  bookings        Booking[]       @relation("TravellerBookings")
  orders          Order[]         @relation("TravellerOrders")
  trips           Trip[]          @relation("TravellerTrips")
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================
// BUS & ROUTE MODELS
// ============================================

model Bus {
  id              Int       @id @default(autoincrement())
  name            String
  number          String    @unique
  type            BusType
  capacity        Int
  amenities       String[]  // ["WiFi", "Charging", "AC", "Washroom"]
  
  operatorId      Int
  operator        User      @relation("BusOperator", fields: [operatorId], references: [id], onDelete: Cascade)
  
  schedules       Schedule[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([operatorId])
}

model Route {
  id              Int       @id @default(autoincrement())
  name            String
  origin          String
  destination     String
  distance        Float     // in kilometers
  duration        Int       // in minutes
  stops           Json      // Array of stop objects: [{ name, lat, lng }]
  
  operatorId      Int?
  operator        User?     @relation("RouteOperator", fields: [operatorId], references: [id], onDelete: Cascade)
  
  schedules       Schedule[]
  restaurants     Restaurant[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([operatorId])
}

model Schedule {
  id              Int       @id @default(autoincrement())
  
  busId           Int
  bus             Bus       @relation(fields: [busId], references: [id], onDelete: Cascade)
  
  routeId         Int
  route           Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  departureTime   DateTime
  arrivalTime     DateTime
  daysOfWeek      String[]  // ["Monday", "Tuesday", ...]
  fare            Float
  availableSeats  Int
  
  bookings        Booking[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([busId])
  @@index([routeId])
}

// ============================================
// BOOKING MODEL
// ============================================

model Booking {
  id              Int           @id @default(autoincrement())
  
  travellerId     Int
  traveller       User          @relation("TravellerBookings", fields: [travellerId], references: [id], onDelete: Cascade)
  
  scheduleId      Int
  schedule        Schedule      @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  
  seatNumbers     String[]
  totalFare       Float
  status          BookingStatus @default(PENDING)
  
  bookingDate     DateTime      @default(now())
  travelDate      DateTime
  
  orders          Order[]       @relation("BookingOrders")
  trips           Trip[]        @relation("TripBookings")
  messages        Message[]     @relation("BookingMessages")
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([travellerId])
  @@index([scheduleId])
}

// ============================================
// RESTAURANT & MENU MODELS
// ============================================

model Restaurant {
  id              Int       @id @default(autoincrement())
  name            String
  description     String?
  location        String
  busStop         String?   // name of the bus stop this restaurant is near
  cuisine         String[]  // ["Indian", "Chinese", "Continental"]
  rating          Float     @default(0)
  image_url       String?
  latitude        Float?
  longitude       Float?
  is_active       Boolean   @default(true)
  
  ownerId         Int
  owner           User      @relation("RestaurantOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  routeId         Int
  route           Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  menuItems       MenuItem[]
  orders          Order[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([ownerId])
  @@index([routeId])
  @@index([busStop])
}

model MenuItem {
  id              Int       @id @default(autoincrement())
  
  restaurantId    Int
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  price           Float
  category        String    // "Appetizer", "Main Course", "Dessert", "Beverage"
  image_url       String?
  is_available    Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([restaurantId])
}

// ============================================
// ORDER MODEL
// ============================================

model Order {
  id              Int         @id @default(autoincrement())
  
  travellerId     Int
  traveller       User        @relation("TravellerOrders", fields: [travellerId], references: [id], onDelete: Cascade)
  
  restaurantId    Int
  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  bookingId       Int?
  booking         Booking?    @relation("BookingOrders", fields: [bookingId], references: [id], onDelete: SetNull)
  
  items           Json        // [{ menuItemId, name, price, quantity }]
  totalAmount     Float
  status          OrderStatus @default(PENDING)
  
  deliveryLocation String?
  deliveryLat     Float?
  deliveryLng     Float?
  deliveryTime    DateTime?
  specialInstructions String?
  
  tripId          Int?
  trip            Trip?       @relation("TripOrders", fields: [tripId], references: [id], onDelete: SetNull)
  
  messages        Message[]   @relation("OrderMessages")
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([travellerId])
  @@index([restaurantId])
  @@index([bookingId])
  @@index([tripId])
}

// ============================================
// TRIP MODEL
// ============================================

model Trip {
  id              Int         @id @default(autoincrement())
  
  travellerId     Int
  traveller       User        @relation("TravellerTrips", fields: [travellerId], references: [id], onDelete: Cascade)
  
  name            String
  destination     String    @default("")
  budget          Float     @default(0)
  description     String?
  
  bookings        Booking[]   @relation("TripBookings")
  orders          Order[]     @relation("TripOrders")
  
  startDate       DateTime
  endDate         DateTime
  status          TripStatus  @default(PLANNED)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([travellerId])
}

// ============================================
// MESSAGE MODEL
// ============================================

model Message {
  id              Int       @id @default(autoincrement())
  
  senderId        Int
  sender          User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  
  receiverId      Int
  receiver        User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  
  bookingId       Int?
  booking         Booking?  @relation("BookingMessages", fields: [bookingId], references: [id], onDelete: Cascade)
  
  orderId         Int?
  order           Order?    @relation("OrderMessages", fields: [orderId], references: [id], onDelete: Cascade)
  
  content         String
  isRead          Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  
  @@index([senderId])
  @@index([receiverId])
  @@index([bookingId])
  @@index([orderId])
}
