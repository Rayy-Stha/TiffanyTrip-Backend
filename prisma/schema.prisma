generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int          @id @default(autoincrement())
  email            String       @unique
  role             UserRole     @default(TRAVELLER)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  full_name        String
  is_verified      Boolean      @default(false)
  otp              String?
  otp_expires_at   DateTime?
  password_hash    String
  phone            String       @unique
  address          String?
  avatar_url       String?
  bookings         Booking[]    @relation("TravellerBookings")
  buses            Bus[]        @relation("BusOperator")
  receivedMessages Message[]    @relation("ReceivedMessages")
  sentMessages     Message[]    @relation("SentMessages")
  orders           Order[]      @relation("TravellerOrders")
  restaurants      Restaurant[] @relation("RestaurantOwner")
  routes           Route[]      @relation("RouteOperator")
  trips            Trip[]       @relation("TravellerTrips")
}

model Bus {
  id         Int        @id @default(autoincrement())
  name       String
  number     String     @unique
  type       BusType
  capacity   Int
  amenities  String[]
  operatorId Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  operator   User       @relation("BusOperator", fields: [operatorId], references: [id], onDelete: Cascade)
  schedules  Schedule[]

  @@index([operatorId])
}

model Route {
  id          Int          @id @default(autoincrement())
  name        String
  origin      String
  destination String
  distance    Float
  duration    Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  operatorId  Int?
  stops       Json
  restaurants Restaurant[]
  operator    User?        @relation("RouteOperator", fields: [operatorId], references: [id], onDelete: Cascade)
  schedules   Schedule[]

  @@index([operatorId])
}

model Schedule {
  id             Int       @id @default(autoincrement())
  busId          Int
  routeId        Int
  departureTime  DateTime
  arrivalTime    DateTime
  daysOfWeek     String[]
  fare           Float
  availableSeats Int
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  bookings       Booking[]
  bus            Bus       @relation(fields: [busId], references: [id], onDelete: Cascade)
  route          Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([busId])
  @@index([routeId])
}

model Booking {
  id          Int           @id @default(autoincrement())
  travellerId Int
  scheduleId  Int
  seatNumbers String[]
  totalFare   Float
  status      BookingStatus @default(PENDING)
  bookingDate DateTime      @default(now())
  travelDate  DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  schedule    Schedule      @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  traveller   User          @relation("TravellerBookings", fields: [travellerId], references: [id], onDelete: Cascade)
  messages    Message[]     @relation("BookingMessages")
  orders      Order[]       @relation("BookingOrders")
  trips       Trip[]        @relation("TripBookings")

  @@index([travellerId])
  @@index([scheduleId])
}

model Restaurant {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  location    String
  cuisine     String[]
  rating      Float      @default(0)
  image_url   String?
  is_active   Boolean    @default(true)
  ownerId     Int
  routeId     Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  latitude    Float?
  longitude   Float?
  busStop     String?
  menuItems   MenuItem[]
  orders      Order[]
  owner       User       @relation("RestaurantOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  route       Route      @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([routeId])
  @@index([busStop])
}

model MenuItem {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  name         String
  description  String?
  price        Float
  category     String
  image_url    String?
  is_available Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Order {
  id                  Int         @id @default(autoincrement())
  travellerId         Int
  restaurantId        Int
  bookingId           Int?
  items               Json
  totalAmount         Float
  status              OrderStatus @default(PENDING)
  deliveryLocation    String?
  deliveryTime        DateTime?
  specialInstructions String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  tripId              Int?
  deliveryLat         Float?
  deliveryLng         Float?
  messages            Message[]   @relation("OrderMessages")
  booking             Booking?    @relation("BookingOrders", fields: [bookingId], references: [id])
  restaurant          Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  traveller           User        @relation("TravellerOrders", fields: [travellerId], references: [id], onDelete: Cascade)
  trip                Trip?       @relation("TripOrders", fields: [tripId], references: [id])

  @@index([travellerId])
  @@index([restaurantId])
  @@index([bookingId])
  @@index([tripId])
}

model Trip {
  id          Int        @id @default(autoincrement())
  travellerId Int
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      TripStatus @default(PLANNED)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  budget      Float      @default(0)
  destination String     @default("")
  orders      Order[]    @relation("TripOrders")
  traveller   User       @relation("TravellerTrips", fields: [travellerId], references: [id], onDelete: Cascade)
  bookings    Booking[]  @relation("TripBookings")

  @@index([travellerId])
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  bookingId  Int?
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  orderId    Int?
  booking    Booking? @relation("BookingMessages", fields: [bookingId], references: [id], onDelete: Cascade)
  order      Order?   @relation("OrderMessages", fields: [orderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([bookingId])
  @@index([orderId])
}

enum UserRole {
  ADMIN
  TRAVELLER
  BUS_OPERATOR
  RESTAURANT
}

enum BusType {
  AC
  NON_AC
  SLEEPER
  SEMI_SLEEPER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum TripStatus {
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}
